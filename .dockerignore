# The repository root is used only by the CPU inference image build.
# Keep its context constrained to the runtime source and model artifacts.
*
!services/
!services/inference-engine/
!services/inference-engine/Cargo.toml
!services/inference-engine/Cargo.lock
!services/inference-engine/src/
!services/inference-engine/src/**
!services/ml-models/
