# INEC Platform Environment Variables
# Copy to .env for local deployment. Do not commit real credentials.

# PostgreSQL primary, replica, and Pgpool
PG_DB=inec_db
PG_USER=inec_admin
PG_PASSWORD=replace_with_a_strong_postgres_password
REPLICATOR_PASSWORD=replace_with_a_strong_replication_password
PGPOOL_ADMIN_USER=pgpool_admin
PGPOOL_ADMIN_PASSWORD=replace_with_a_strong_pgpool_password
DATABASE_URL=postgres://inec_admin:replace_with_a_strong_postgres_password@localhost:5432/inec_db?sslmode=disable
DATABASE_REPLICA_URL=postgres://inec_admin:replace_with_a_strong_postgres_password@localhost:5433/inec_db?sslmode=disable

# Platform security, API gateway, and tally decryption
JWT_SECRET=replace_with_a_secure_32_byte_secret_key
HSM_MASTER_KEY=replace_with_a_64_character_hex_256_bit_key
APISIX_ADMIN_KEY=replace_with_a_strong_apisix_admin_key
TALLY_DECRYPT_TOKEN=replace_with_a_strong_tally_decryption_token
CORS_ORIGINS=https://inec.local
ALLOWED_ORIGINS=https://inec.local

# Keycloak SSO / OIDC
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=inec
KEYCLOAK_CLIENT_ID=inec-backend
KEYCLOAK_CLIENT_SECRET=replace_with_keycloak_client_secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace_with_a_strong_keycloak_bootstrap_password
INEC_ADMIN_PASSWORD=replace_with_a_strong_inec_admin_password
OFFICER_PASSWORD=replace_with_a_strong_presiding_officer_password
OBSERVER_PASSWORD=replace_with_a_strong_observer_password

# Permify relationship-based authorization
PERMIFY_URL=http://permify:3476
PERMIFY_TENANT_ID=inec

# TigerBeetle native ledger connection
TIGERBEETLE_URL=tigerbeetle:3001

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka and Dapr pub/sub
KAFKA_BROKERS=kafka:29092
KAFKA_REST_URL=http://kafka-rest:8082
DAPR_HTTP_PORT=3500

# Temporal durable workflows
TEMPORAL_HOST_PORT=temporal:7233
TEMPORAL_NAMESPACE=default

# Fluvio streaming through the official Rust SDK bridge
FLUVIO_ENDPOINT=fluvio-sc:9003
FLUVIO_STREAM_URL=http://fluvio-stream:8100
FLUVIO_TOPIC_AUDIT=inec.audit.log
FLUVIO_TOPIC_RESULTS=inec.results.submitted

# Lakehouse, CPU inference, and biometric capture pipeline
LAKEHOUSE_URL=http://lakehouse:8090
RUST_INFERENCE_URL=http://inference-engine:8091
BIOMETRIC_PIPELINE_URL=http://biometric-go:8092
BIOMETRIC_PYTHON_URL=http://biometric-python:8090
BIOMETRIC_RUST_URL=http://biometric-rust:8091
MODELS_DIR=/app/models

# OpenAppSec APISIX attachment / standalone agent
APPSEC_VERSION=latest
OPENAPPSEC_DB_PASSWORD=replace_with_a_strong_openappsec_database_password
OPENAPPSEC_GATEWAY_ENFORCED=true

# Optional external integrations
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
