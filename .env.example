# INEC Platform Environment Variables
# Copy to .env for local deployment. Do not commit real credentials.

# PostgreSQL primary, replica, and Pgpool
PG_DB=replace_with_postgres_database_name
PG_USER=replace_with_postgres_user
PG_PASSWORD=replace_with_a_strong_postgres_password
REPLICATOR_PASSWORD=replace_with_a_strong_replication_password
PGPOOL_ADMIN_USER=replace_with_pgpool_admin_user
PGPOOL_ADMIN_PASSWORD=replace_with_a_strong_pgpool_password
DATABASE_URL=postgres://replace_with_postgres_user:replace_with_a_strong_postgres_password@localhost:5432/replace_with_postgres_database_name?sslmode=disable
DATABASE_REPLICA_URL=postgres://replace_with_postgres_user:replace_with_a_strong_postgres_password@localhost:5433/replace_with_postgres_database_name?sslmode=disable

# Platform security, API gateway, and tally decryption
JWT_SECRET=replace_with_a_secure_32_byte_secret_key
HSM_MASTER_KEY=replace_with_a_64_character_hex_256_bit_key
APISIX_ADMIN_KEY=replace_with_a_strong_apisix_admin_key
TALLY_DECRYPT_TOKEN=replace_with_a_strong_tally_decryption_token
CORS_ORIGINS=https://inec.local
ALLOWED_ORIGINS=https://inec.local

# Keycloak SSO / OIDC
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=inec
KEYCLOAK_CLIENT_ID=inec-backend
KEYCLOAK_CLIENT_SECRET=replace_with_keycloak_client_secret
KEYCLOAK_ADMIN=replace_with_keycloak_bootstrap_admin
KEYCLOAK_ADMIN_PASSWORD=replace_with_a_strong_keycloak_bootstrap_password
INEC_ADMIN_PASSWORD=replace_with_a_strong_inec_admin_password
OFFICER_PASSWORD=replace_with_a_strong_presiding_officer_password
OBSERVER_PASSWORD=replace_with_a_strong_observer_password

# Permify relationship-based authorization
PERMIFY_URL=http://permify:3476
PERMIFY_TENANT_ID=inec

# TigerBeetle native ledger connection
TIGERBEETLE_URL=tigerbeetle:3001

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka and Dapr pub/sub
KAFKA_BROKERS=kafka:29092
KAFKA_REST_URL=http://kafka-rest:8082
DAPR_HTTP_PORT=3500

# Temporal durable workflows
TEMPORAL_HOST_PORT=temporal:7233
TEMPORAL_NAMESPACE=default

# Fluvio streaming through the official Rust SDK bridge
FLUVIO_ENDPOINT=fluvio-sc:9003
FLUVIO_STREAM_URL=http://fluvio-stream:8100
FLUVIO_TOPIC_AUDIT=inec.audit.log
FLUVIO_TOPIC_RESULTS=inec.results.submitted

# Lakehouse, CPU inference, and biometric capture pipeline
LAKEHOUSE_URL=http://lakehouse:8090
RUST_INFERENCE_URL=http://inference-engine:8091
BIOMETRIC_PIPELINE_URL=http://biometric-go:8092
BIOMETRIC_PYTHON_URL=http://biometric-python:8090
BIOMETRIC_RUST_URL=http://biometric-rust:8091
MODELS_DIR=/app/models

# OpenAppSec APISIX attachment / standalone agent
APPSEC_VERSION=replace_with_verified_openappsec_version
OPENAPPSEC_DB_PASSWORD=replace_with_a_strong_openappsec_database_password
OPENAPPSEC_GATEWAY_ENFORCED=true

# Satellite imagery through a real STAC provider
SATELLITE_SERVICE_URL=http://satellite-change-detection:8204
STAC_API_URL=https://replace_with_your_stac_api.example/v1
STAC_COLLECTION=replace_with_stac_collection
STAC_PREVIEW_ASSET=replace_with_preview_asset_name
STAC_MAX_CLOUD_COVER=replace_with_maximum_cloud_cover_percent

# Standalone biometric service
INFERENCE_ENGINE_URL=http://inference-engine:8091
VAULT_KEY=replace_with_64_character_hex_256_bit_key

# Optional external integrations
OPENAI_API_KEY=replace_with_openai_api_key_if_campaign_planning_is_enabled
OPENAI_API_BASE=https://replace_with_openai_compatible_api_base

# Document AI and trained CPU model services
DOCUMENT_AI_URL=http://document-ai:8089
INFERENCE_ENGINE_URL=http://inference-engine:8091
BIOMETRIC_LIVENESS_URL=http://inference-engine:8091/liveness/predict
VLM_ENDPOINT=https://replace_with_your_openai_compatible_vision_endpoint
VLM_MODEL=replace_with_your_vision_model_name
NIN_API_URL=https://replace_with_authorized_nimc_verification_endpoint
NIN_API_KEY=replace_with_authorized_nimc_api_key

# Digital twin and campaign planning AI
OPENAI_MODEL=replace_with_authorized_scenario_and_campaign_model
CAMPAIGN_PLANNING_URL=http://campaign-planning:8007
INEC_API_URL=http://go-backend:8088

# Predictive resource allocation trained from real historical results
MIN_TRAINING_SAMPLES=replace_with_minimum_real_historical_result_count
RESOURCE_BALLOT_BUFFER=replace_with_ballot_spoilage_buffer_fraction
RESOURCE_VOTERS_PER_CLERK=replace_with_authorised_voter_to_clerk_ratio
RESOURCE_MIN_POLL_CLERKS=replace_with_authorised_minimum_poll_clerks
RESOURCE_MIN_SECURITY_PERSONNEL=replace_with_authorised_minimum_security_personnel
