# INEC Platform Environment Variables
# Do NOT commit the actual .env file to version control

# PostgreSQL Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/inec?sslmode=disable

# JWT Authentication
JWT_SECRET=replace_this_with_a_secure_32_byte_secret_key

# Keycloak SSO
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=inec
KEYCLOAK_CLIENT_ID=inec-backend
KEYCLOAK_CLIENT_SECRET=replace_this_secret

# Permify Authorization
PERMIFY_ENDPOINT=localhost:3476
PERMIFY_TENANT_ID=t1

# TigerBeetle Ledger
TB_CLUSTER_ID=0
TB_REPLICA_ADDRESSES=3000

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Temporal Workflows
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=default

# Fluvio Streaming
FLUVIO_TOPIC_AUDIT=audit-logs
FLUVIO_TOPIC_RESULTS=election-results
