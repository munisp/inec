#!/usr/bin/env bash
# Seed approved non-production PostgreSQL fixtures through cmd/dbseed.
# This wrapper intentionally has no database or credential defaults.
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKEND_DIR="$ROOT_DIR/inec-go-backend"

: "${DATABASE_URL:?DATABASE_URL is required}"
: "${DBSEED_ENV:?DBSEED_ENV must be development or test}"

case "$DBSEED_ENV" in
  development|test) ;;
  *)
    printf 'seed_database: DBSEED_ENV must be development or test; got %q\n' "$DBSEED_ENV" >&2
    exit 2
    ;;
esac

case "${APP_ENV:-}" in
  production)
    printf 'seed_database: refusing to operate when APP_ENV=production\n' >&2
    exit 2
    ;;
esac

cd "$BACKEND_DIR"
exec go run ./cmd/dbseed \
  --dsn "$DATABASE_URL" \
  --fixtures "$ROOT_DIR/fixtures/db" \
  --environment "$DBSEED_ENV" \
  --confirm-non-production \
  "$@"
